{
  "info": {
    "name": "Task 2 - Project 3 - Profile Picture API",
    "description": "File upload linked to a user profile. Run 'Create User' first (stores {{userId}}), then 'Upload Picture' (select an image for the 'image' form-data field).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5005" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
      }
    },
    {
      "name": "Create User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "if (res.data && res.data._id) pm.collectionVariables.set('userId', res.data._id);",
              "pm.test('status is 201', () => pm.response.to.have.status(201));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Asha\",\n  \"email\": \"asha@example.com\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
      }
    },
    {
      "name": "Get User",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] }
      }
    },
    {
      "name": "Upload Picture",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [{ "key": "image", "type": "file", "src": [] }]
        },
        "url": { "raw": "{{baseUrl}}/users/{{userId}}/picture", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}", "picture"] }
      },
      "description": "Select a local JPEG/PNG/GIF (<=5MB) for the 'image' field before sending."
    },
    {
      "name": "Get Picture (metadata + URL)",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/users/{{userId}}/picture", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}", "picture"] }
      }
    },
    {
      "name": "Delete Picture",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": { "raw": "{{baseUrl}}/users/{{userId}}/picture", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}", "picture"] }
      }
    }
  ]
}
