{
  "info": {
    "name": "Task 2 - Project 2 - Blog API",
    "description": "Blog API with CRUD, pagination, filtering (tag/author/date) and sorting. Run 'Create Post' first; it stores the new id in {{postId}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5004" },
    { "key": "postId", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
      }
    },
    {
      "name": "Create Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "if (res.data && res.data._id) pm.collectionVariables.set('postId', res.data._id);",
              "pm.test('status is 201', () => pm.response.to.have.status(201));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Getting Started with Node\",\n  \"body\": \"Node.js is a JavaScript runtime...\",\n  \"author\": \"john\",\n  \"tags\": [\"node\", \"backend\"]\n}"
        },
        "url": { "raw": "{{baseUrl}}/posts", "host": ["{{baseUrl}}"], "path": ["posts"] }
      }
    },
    {
      "name": "Create Post - Invalid (missing body)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"No Body\",\n  \"author\": \"john\"\n}" },
        "url": { "raw": "{{baseUrl}}/posts", "host": ["{{baseUrl}}"], "path": ["posts"] }
      }
    },
    {
      "name": "Get All Posts",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/posts", "host": ["{{baseUrl}}"], "path": ["posts"] }
      }
    },
    {
      "name": "Get Posts - Filter by Tag",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts?tag=node",
          "host": ["{{baseUrl}}"],
          "path": ["posts"],
          "query": [{ "key": "tag", "value": "node" }]
        }
      }
    },
    {
      "name": "Get Posts - Filter by Author",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts?author=john",
          "host": ["{{baseUrl}}"],
          "path": ["posts"],
          "query": [{ "key": "author", "value": "john" }]
        }
      }
    },
    {
      "name": "Get Posts - Date Range",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts?from=2024-01-01&to=2030-12-31",
          "host": ["{{baseUrl}}"],
          "path": ["posts"],
          "query": [
            { "key": "from", "value": "2024-01-01" },
            { "key": "to", "value": "2030-12-31" }
          ]
        }
      }
    },
    {
      "name": "Get Posts - Pagination + Sort",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts?page=1&limit=5&sort=oldest",
          "host": ["{{baseUrl}}"],
          "path": ["posts"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "5" },
            { "key": "sort", "value": "oldest" }
          ]
        }
      }
    },
    {
      "name": "Get Posts - Combined Filters",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts?tag=node&author=john&sort=newest&page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["posts"],
          "query": [
            { "key": "tag", "value": "node" },
            { "key": "author", "value": "john" },
            { "key": "sort", "value": "newest" },
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        }
      }
    },
    {
      "name": "Get Post By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/posts/{{postId}}", "host": ["{{baseUrl}}"], "path": ["posts", "{{postId}}"] }
      }
    },
    {
      "name": "Update Post",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Getting Started with Node (updated)\",\n  \"tags\": [\"node\", \"express\"]\n}" },
        "url": { "raw": "{{baseUrl}}/posts/{{postId}}", "host": ["{{baseUrl}}"], "path": ["posts", "{{postId}}"] }
      }
    },
    {
      "name": "Delete Post",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": { "raw": "{{baseUrl}}/posts/{{postId}}", "host": ["{{baseUrl}}"], "path": ["posts", "{{postId}}"] }
      }
    }
  ]
}
