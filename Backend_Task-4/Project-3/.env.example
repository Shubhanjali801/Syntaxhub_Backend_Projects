PORT=5011
MONGO_URI=mongodb://localhost:27017/syntecxhub_scheduler
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=1h
ADMIN_SECRET=super_admin_bootstrap_secret

# Cron schedules (override the in-code defaults if set)
CRON_DELETE_STALE=0 * * * *
CRON_EMAIL_SUMMARY=0 8 * * *

# Set true to run scheduled jobs automatically on startup; false to register them
# as manual-only (still triggerable via the API). Defaults to true.
ENABLE_SCHEDULER=true

# Records with no explicit expiry are considered stale after this many days.
STALE_RECORD_DAYS=30

# Where the (mock) email summary is "sent". No real SMTP is used.
SUMMARY_EMAIL=admin@example.com
