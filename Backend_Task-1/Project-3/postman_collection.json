{
  "info": {
    "name": "Task 1 - Project 3 - File Upload API",
    "description": "File/Image Upload API (multer, images only, 5MB max). For 'Upload Image', select a local image file for the 'image' form-data field, then Send. The new id is stored in {{fileId}} and filename in {{fileName}} for the other requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5002" },
    { "key": "fileId", "value": "" },
    { "key": "fileName", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
      }
    },
    {
      "name": "Upload Image",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "if (res.data) {",
              "  if (res.data._id) pm.collectionVariables.set('fileId', res.data._id);",
              "  if (res.data.filename) pm.collectionVariables.set('fileName', res.data.filename);",
              "}",
              "pm.test('status is 201', () => pm.response.to.have.status(201));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "image", "type": "file", "src": [] }
          ]
        },
        "url": { "raw": "{{baseUrl}}/upload", "host": ["{{baseUrl}}"], "path": ["upload"] }
      },
      "description": "Select a local JPEG/PNG/GIF (<=5MB) for the 'image' field before sending."
    },
    {
      "name": "Upload - No File (expect 400)",
      "request": {
        "method": "POST",
        "header": [],
        "body": { "mode": "formdata", "formdata": [] },
        "url": { "raw": "{{baseUrl}}/upload", "host": ["{{baseUrl}}"], "path": ["upload"] }
      }
    },
    {
      "name": "Get All Files",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/files", "host": ["{{baseUrl}}"], "path": ["files"] }
      }
    },
    {
      "name": "Get File By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/files/{{fileId}}", "host": ["{{baseUrl}}"], "path": ["files", "{{fileId}}"] }
      }
    },
    {
      "name": "Serve Image (static)",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/uploads/{{fileName}}", "host": ["{{baseUrl}}"], "path": ["uploads", "{{fileName}}"] }
      }
    },
    {
      "name": "Delete File",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": { "raw": "{{baseUrl}}/files/{{fileId}}", "host": ["{{baseUrl}}"], "path": ["files", "{{fileId}}"] }
      }
    }
  ]
}
