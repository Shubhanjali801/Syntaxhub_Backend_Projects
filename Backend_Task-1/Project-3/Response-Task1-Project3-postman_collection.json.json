      "name": "Upload Image",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "if (res.data) {",
              "  if (res.data._id) pm.collectionVariables.set('fileId', res.data._id);",
              "  if (res.data.filename) pm.collectionVariables.set('fileName', res.data.filename);",
              "}",
              "pm.test('status is 201', () => pm.response.to.have.status(201));"
            ]
          }
        }
      ],
